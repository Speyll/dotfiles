#!/bin/sh

# --- Config ---
LOG="/tmp/autostart.log"
AUDIO=false
MODE="swaybg-random-online"
THEME_MODE="none" # auto, fixed, none
THEME_NAME="gruvbox-dark-medium"
CURSOR="Kaela-Kovalskia-v2"
WAYBAR_STYLE="none"
UPDATE_SCAN=true

# URLs & Paths
DWALL="$HOME/pictures/walls/wall.jpg"
DVWALL="$HOME/pictures/walls/vert-wall.jpg"
P_WALL="https://pastebin.com/raw/7YwMgZXg"
P_VWALL="https://pastebin.com/raw/Q8GUUAse"
P_VID="https://pastebin.com/raw/yHFpxMDB"
P_VVID="https://pastebin.com/raw/NTVA8RMd"

# --- Initialization ---
exec >> "$LOG" 2>&1
echo "=== Autostart: $(date) ==="

# 1. Wait for Compositor
timeout=20
while [ -z "$WAYLAND_DISPLAY" ] && [ "$timeout" -gt 0 ]; do
    sleep 0.5
    timeout=$((timeout - 1))
done

# 2. Cleanup (DO THIS BEFORE STARTING NEW SERVICES)
for p in flavours mpvpaper swaybg fnott wlsunset cliphist waybar mako; do
    pkill -x "$p" >/dev/null 2>&1
done

# 3. Environment & Auth
dbus-update-activation-environment --all
export XDG_CURRENT_DESKTOP=sway # or Hyprland, adjust as needed

if command -v gnome-keyring-daemon >/dev/null; then
    eval $(gnome-keyring-daemon --start --components=secrets)
    export SSH_AUTH_SOCK
fi

/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

# 4. Interface Settings
gsettings set org.gnome.desktop.interface cursor-theme "$CURSOR"
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
# Note: seat command is specific to Sway config; if running in a script,
# ensure it's piped to swaymsg if you are using Sway.
command -v swaymsg >/dev/null && swaymsg seat seat0 xcursor_theme "$CURSOR"

# 5. Core Services
wlsunset -l 36.7 -L 3.08 &
mako &
wl-paste --type text --watch cliphist store &
wl-paste --type image --watch cliphist store &
hypridle &

if [ "$WAYBAR_STYLE" != "none" ]; then
    waybar -c "$HOME/.config/waybar/$WAYBAR_STYLE-config" -s "$HOME/.config/waybar/style.css" &
fi

if command -v openrgb >/dev/null; then
    openrgb --server -p pureWhite &
fi

# 6. Audio
if [ "$AUDIO" = true ]; then
    pipewire &
    sleep 1
    wireplumber &
    pipewire-pulse &
fi

# --- Helper Functions ---
get_orient() {
    wlr-randr | awk '/^[A-Za-z0-9-]+/ {o=$1} /Transform:/ {print o ":" ($2 ~ /90|270/ ? "portrait" : "landscape")}'
}

fetch_url() {
    curl -fsSL "$1" | shuf -n1 | tr -d '\r\n'
}

apply_swaybg() {
    get_orient | while IFS=: read -r o or; do
        img=$([ "$or" = "portrait" ] && echo "$2" || echo "$1")
        swaybg -o "$o" -i "$img" -m fill &
    done
}

apply_mpvpaper() {
    get_orient | while IFS=: read -r o or; do
        [ "$or" = "portrait" ] && fmt="bestvideo[width<=?1080]" vid="$2" || fmt="bestvideo[height<=?1080]" vid="$1"
        mpvpaper -vsp -o "no-audio pause=no --loop --ytdl-format=$fmt" "$o" "$vid" &
    done
}

# --- Aesthetics (Backgrounded) ---
handle_aesthetics() {
    case "$MODE" in
        swaybg-random-online)
            apply_swaybg "$DWALL" "$DVWALL"
            w_url=$(fetch_url "$P_WALL")
            vw_url=$(fetch_url "$P_VWALL")
            curl -fsSL "$w_url" -o /tmp/wall.jpg &
            curl -fsSL "$vw_url" -o /tmp/vert_wall.jpg &
            wait
            pkill -x swaybg
            apply_swaybg /tmp/wall.jpg /tmp/vert_wall.jpg
            ;;
        swaybg-random)
            w=$(find "$HOME/pictures/walls/" -maxdepth 1 -name "*.jpg" | shuf -n1)
            vw=$(find "$HOME/pictures/walls/" -maxdepth 1 -name "vert-*.jpg" | shuf -n1)
            apply_swaybg "${w:-$DWALL}" "${vw:-$DVWALL}"
            ;;
        mpvpaper-online)
            apply_mpvpaper "$(fetch_url "$P_VID")" "$(fetch_url "$P_VVID")"
            ;;
        *) # Fallback/Default
            apply_swaybg "$DWALL" "$DVWALL"
            ;;
    esac

    # Theme Apply
    [ "$THEME_MODE" = "auto" ] && [ -f /tmp/wall.jpg ] && flavours generate dark /tmp/wall.jpg && flavours apply generated
    [ "$THEME_MODE" = "fixed" ] && flavours apply "$THEME_NAME"
}

handle_aesthetics &

# 7. Delayed Tasks
[ "$UPDATE_SCAN" = true ] && (sleep 10; "$HOME/.local/bin/updtscan") &
