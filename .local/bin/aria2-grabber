#!/bin/bash

# Set the path for your text file
TEXT_FILE="$HOME/downloads/links.txt"

# Set the path for the downloaded links file
DOWNLOADED_FILE="$HOME/downloads/downloaded_links.txt"

# Create an empty links.txt file if it doesn't exist
touch "$TEXT_FILE"

# Create an empty downloaded links file if it doesn't exist
touch "$DOWNLOADED_FILE"

# Function to check if a link is already downloaded
is_link_downloaded() {
    link="$1"
    grep -q "$link" "$DOWNLOADED_FILE"
}

# Function to add a link to the text file
add_link_to_file() {
    link="$1"

    # Check if the link is already downloaded
    if is_link_downloaded "$link"; then
        notify-send --expire-time=5000 "Link Already Downloaded" "$link"
        return
    fi

    # Check if the link is already in the file
    if grep -q "$link" "$TEXT_FILE"; then
        return
    fi

    echo "$link" >> "$TEXT_FILE"
    notify-send --expire-time=5000 "Link Added" "$link"
}

# Function to run aria2c with the links in the text file
run_bulk_download() {
    # Only run if there are new links to download
    if [ -s "$TEXT_FILE" ]; then
        aria2c --dir="/media/ST500/pron/dump/toEncode" -i "$TEXT_FILE" -j 3
        cat "$TEXT_FILE" >> "$DOWNLOADED_FILE"
        > "$TEXT_FILE" # Clear the links.txt file
    fi
}

# Main loop to listen to the clipboard and add links
while true; do
    # Get the clipboard content using wl-paste
    NEW_LINK=$(wl-paste)

    # Check if it's a valid link (you can add more checks if needed)
    if [ "$(echo "$NEW_LINK" | grep -E '^https?://')" ]; then
        # Append the link to the text file if not added already
        add_link_to_file "$NEW_LINK"

        # Run aria2c with the links in the text file
        run_bulk_download
    fi

    # Wait for a change in the clipboard content
    while [ "$NEW_LINK" == "$(wl-paste)" ]; do
        sleep 1
    done
done
