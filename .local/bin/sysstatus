#!/bin/sh
# Lightweight, ultra-lean barless status reporter for Mako
# Uses raw system files to avoid heavy CLI execution overhead.

# --- 1. Fast Metrics Gathering (All in-memory parsing) ---

# Time & Date (Single process execution)
DATETIME=$(date +"%A, %b %d | %I:%M %p")

# Battery Stats via direct kernel sysfs read
BAT_DIR="/sys/class/power_supply/BAT0"
if [ -d "$BAT_DIR" ]; then
    BAT_PCT=$(cat "$BAT_DIR/capacity" 2>/dev/null)
    BAT_STAT=$(cat "$BAT_DIR/status" 2>/dev/null)

    # Map raw charging states to clean visual indicators
    case "$BAT_STAT" in
        "Charging")    BAT_ICON="⚡" ;;
        "Full")        BAT_ICON="🔌" ;;
        *)             BAT_ICON="🔋" ;;
    esac
    BAT_STR="${BAT_ICON} ${BAT_PCT}%"
else
    BAT_STR="🔌 Desktop Mode"
fi

# RAM Consumption via direct /proc/meminfo parsing with awk
MEM_STR=$(awk '
    /^MemTotal:/ {total=$2}
    /^MemAvailable:/ {avail=$2}
    END {
        used=(total-avail)/1024/1024;
        print sprintf("%.2f GB", used)
    }
' /proc/meminfo)

# Network State tracking via operstate
NET_STR="󰈀 Offline"
for dev in /sys/class/net/*; do
    # Skip loopback interface
    [ "${dev##*/}" = "lo" ] && continue
    if [ "$(cat "$dev/operstate" 2>/dev/null)" = "up" ]; then
        case "${dev##*/}" in
            wlan*|wlp*) NET_STR=" Wi-Fi Connected" ;;
            eth*|enp*)  NET_STR="󰈀 Ethernet Connected" ;;
        esac
        break
    fi
done

# --- 2. Actionable Output Dispatch ---

# We inject an explicit category ("status-popup") so Mako drops old versions
# immediately instead of generating spam bubbles.
notify-send \
    -a "System Status" \
    -h string:x-canonical-private-synchronous:status-popup \
    -t 4000 \
    "${DATETIME}" \
    "<b>Battery:</b>  ${BAT_STR}\n<b>Memory:</b>  ${MEM_STR}\n<b>Network:</b>  ${NET_STR}"
