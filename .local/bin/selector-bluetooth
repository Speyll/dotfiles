#!/bin/sh

# Run bluetoothctl in a subshell
{
    # Start bluetoothctl
    bluetoothctl <<EOF

    # List available Bluetooth devices and assign them numbers
    devices
EOF
} | awk '/Device/ {print NR ". " $2}' | while read -r line; do
    device_number=$(echo "$line" | awk '{print $1}')
    device_mac=$(echo "$line" | awk '{print $2}')
    
    # Try to get the device name
    device_name=$(bluetoothctl info "$device_mac" | awk -F 'Name: ' '/Name/ {print $2}')
    
    if [ -n "$device_name" ]; then
        echo "$device_number. $device_name ($device_mac)"
    else
        echo "$device_number. $device_mac"
    fi
done

# Prompt the user to select a Bluetooth device
read -p "Enter the number of the Bluetooth device to connect to: " choice

# Find the corresponding Bluetooth device MAC address
device_mac=$(bluetoothctl devices | awk '/Device/ {if (NR == '$choice') print $2}')

# Check if the user entered a valid choice
if [ -n "$device_mac" ]; then
    # Connect to the selected Bluetooth device
    bluetoothctl connect "$device_mac"
else
    echo "Invalid selection. No connection was made."
fi
