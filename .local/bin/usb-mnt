#!/bin/bash

# Get the list of removable disk devices
removable_devices=$(lsblk -nrpo name,rm | awk '$2 == 1 {print $1}')

if [ -z "$removable_devices" ]; then
    echo "No removable disk devices found."
    exit 1
fi

echo "Available removable disk devices:"
select device in $removable_devices; do
    if [ -n "$device" ]; then
        mount_point="$HOME/.var/usb/"
        mkdir -p "$mount_point"
        sudo mount "$device" "$mount_point"
        echo "Disk mounted at $mount_point"
        exit 0
    fi
done

echo "No device selected."