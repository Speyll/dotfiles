#!/bin/sh
# Hyper-optimized Fuzzel Launcher Menu
# Stripped of heavy subshell overhead for instant execution

# --- Config ---
FONT="monospace:size=14"
ALIGN="center"
FUZZEL_CMD="fuzzel -d -f $FONT -a $ALIGN"

CACHE_TODO="$HOME/.cache/todo.cache"
CACHE_TODO_TMP="$HOME/.cache/todo2.cache"

# --- Helper Functions ---
show_menu() {
    printf "%b" "$1" | $FUZZEL_CMD -w "$2" -l "$3"
}

launch_app() {
    if command -v "$1" >/dev/null 2>&1; then
        exec "$@"
    # If it's a flatpak command, pass it directly to exec without command -v check
    elif [ "$1" = "flatpak" ]; then
        exec "$@"
    else
        echo "$1 not found" >&2
        exit 1
    fi
}

# --- Menu Handlers ---
handle_conn_menu() {
    case "$(show_menu "$conn_menu" 14 2)" in
        "у°ҲҖ Network")   exec alacritty -T "Network Manager" -e nmtui ;;
        "пҠ“ Bluetooth") exec alacritty -T "Bluetooth Manager" -e bluetui ;;
    esac
}

handle_utils_menu() {
    case "$(show_menu "$utils_menu" 13 5)" in
        "рҹ“‘ Todo")      exec_fuzzel_todo ;;
        "рҹ’» Streaming") exec_fuzzel_streaming ;;
        "рҹ”ў Calc")      exec_fuzzel_calc ;;
        "вҡҷпёҸ Run")       exec_fuzzel_run ;;
        "вҢЁпёҸ Keyboard")  toggle_keyboard ;;
    esac
}

handle_power_menu() {
    case "$(show_menu "$power_menu" 11 4)" in
        "пҖ‘ Shutdown") sudo poweroff ;;
        "пҲ¶ Suspend")  sudo systemctl suspend ;;
        "пҖһ Reboot")   sudo reboot ;;
        "пҖЈ Lock")     hyprlock ;;
    esac
}

exec_fuzzel_streaming() {
    platform_choice=$(show_menu "$streaming_menu" 9 2)
    [ -z "$platform_choice" ] && exit

    case "$platform_choice" in
        "п…Ә Media")  input_link=$(wl-paste) ;;
        "пҮЁ Twitch")
            channel_name=$(fuzzel -d -p "type twitch name: " -f "$FONT" -w 40 -l 0 -a "$ALIGN" /dev/null)
            [ -z "$channel_name" ] && exit
            input_link="https://twitch.tv/$channel_name"
            ;;
        *) exit 1 ;;
    esac

    case "$(show_menu "$media_type_menu" 9 2)" in
        "пҖҪ Video") mpv --pause=no "$input_link" ;;
        "оҳё Audio") foot -T "MPV Terminal" -e mpv --pause=no --no-video --volume=100 "$input_link" ;;
    esac
}

toggle_keyboard() {
    pkill -x wvkbd-mobintl || wvkbd-mobintl -H 50 -R 5 --bg "#282828" --fg "#ffffff" --fn "monospace 12" --alpha 200 &
}

exec_fuzzel_calc() {
    LAST=""
    while :; do
        NEXT=$(fuzzel -l 0 --dmenu -p "${LAST} ")
        [ -z "$NEXT" ] && exit
        [ "$NEXT" = "y" ] && printf "%s" "$LAST" | wl-copy && exit

        LAST=$(echo "$LAST$NEXT" | bc -l)
        case "$LAST" in *.*) LAST=${LAST%%0}; LAST=${LAST%.};; esac
    done
}

exec_fuzzel_todo() {
    touch "$CACHE_TODO"
    cache_contents=$(cat "$CACHE_TODO")
    cache_lines=$(printf "%s" "$cache_contents" | grep -c "^")

    selection=$(printf "%s" "$cache_contents" | fuzzel --dmenu -l "${cache_lines:-0}")
    [ -z "$selection" ] && exit

    if grep -Fxq "$selection" "$CACHE_TODO"; then
        grep -Fxv "$selection" "$CACHE_TODO" > "$CACHE_TODO_TMP" || true
        mv "$CACHE_TODO_TMP" "$CACHE_TODO"
    else
        printf "%s\n" "$selection" >> "$CACHE_TODO"
    fi
}

exec_fuzzel_run() {
    selected=$(fuzzel --dmenu < /dev/null)
    [ -n "$selected" ] && exec "$selected"
}

# --- Menu Data Definitions ---
main_menu="рҹ–ҘпёҸ Terminal\nрҹ—ғпёҸ Explorer\nрҹ“Ұ Apps\nрҹҢҗ Network\nвҡҷпёҸ Utils\nрҹ”Ң Power"
conn_menu="у°ҲҖ Network\nпҠ“ Bluetooth"
utils_menu="рҹ“‘ Todo\nрҹ’» Streaming\nрҹ”ў Calc\nвҡҷпёҸ Run\nвҢЁпёҸ Keyboard"
power_menu="пҖ‘ Shutdown\nпҲ¶ Suspend\nпҖһ Reboot\nпҖЈ Lock"
streaming_menu="п…Ә Media\nпҮЁ Twitch"
media_type_menu="пҖҪ Video\nоҳё Audio"

# --- Main Logic Pipeline ---
# Note: I bumped the layout lines count to 6 since we added a new option to the main list
case "$(show_menu "$main_menu" 13 6)" in
    "рҹ–ҘпёҸ Terminal") launch_app alacritty ;;
    "рҹ—ғпёҸ Explorer") launch_app pcmanfm-qt ;;
    "рҹ“Ұ Apps")      launch_app fuzzel ;;
    "рҹҢҗ Network")      handle_conn_menu ;;
    "вҡҷпёҸ Utils")    handle_utils_menu ;;
    "рҹ”Ң Power")    handle_power_menu ;;
esac
