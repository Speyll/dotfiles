#!/bin/sh
# Hyper-optimized Fuzzel Launcher Menu
# Stripped of heavy subshell overhead for instant execution

# --- Config ---
FONT="monospace:size=14"
ALIGN="center"
FUZZEL_CMD="fuzzel -d -f $FONT -a $ALIGN"

CACHE_TODO="$HOME/.cache/todo.cache"
CACHE_TODO_TMP="$HOME/.cache/todo2.cache"

# --- Helper Functions ---
show_menu() {
    printf "%b" "$1" | $FUZZEL_CMD -w "$2" -l "$3"
}

launch_app() {
    if command -v "$1" >/dev/null 2>&1; then
        exec "$@"
    # If it's a flatpak command, pass it directly to exec without command -v check
    elif [ "$1" = "flatpak" ]; then
        exec "$@"
    else
        echo "$1 not found" >&2
        exit 1
    fi
}

# --- Menu Handlers ---
handle_utils_menu() {
    case "$(show_menu "$utils_menu" 13 5)" in
        "📑 Todo")      exec_fuzzel_todo ;;
        "💻 Streaming") exec_fuzzel_streaming ;;
        "🔢 Calc")      exec_fuzzel_calc ;;
        "⚙️ Run")       exec_fuzzel_run ;;
        "⌨️ Keyboard")  toggle_keyboard ;;
    esac
}

handle_power_menu() {
    case "$(show_menu "$power_menu" 11 4)" in
        " Shutdown") sudo poweroff ;;
        " Suspend")  sudo systemctl suspend ;; # Updated 'halt' to standard systemctl suspend
        " Reboot")   sudo reboot ;;
        " Lock")     hyprlock ;; # Swapped hyprlock for your native Niri session lock
    esac
}

exec_fuzzel_streaming() {
    platform_choice=$(show_menu "$streaming_menu" 9 2)
    [ -z "$platform_choice" ] && exit

    case "$platform_choice" in
        " Media")  input_link=$(wl-paste) ;;
        " Twitch")
            channel_name=$(fuzzel -d -p "type twitch name: " -f "$FONT" -w 40 -l 0 -a "$ALIGN" /dev/null)
            [ -z "$channel_name" ] && exit
            input_link="https://twitch.tv/$channel_name"
            ;;
        *) exit 1 ;;
    esac

    case "$(show_menu "$media_type_menu" 9 2)" in
        " Video") mpv --pause=no "$input_link" ;;
        " Audio") foot -T "MPV Terminal" -e mpv --pause=no --no-video --volume=100 "$input_link" ;;
    esac
}

toggle_keyboard() {
    pkill -x wvkbd-mobintl || wvkbd-mobintl -H 50 -R 5 --bg "#282828" --fg "#ffffff" --fn "monospace 12" --alpha 200 &
}

exec_fuzzel_calc() {
    LAST=""
    while :; do
        NEXT=$(fuzzel -l 0 --dmenu -p "${LAST} ")
        [ -z "$NEXT" ] && exit
        [ "$NEXT" = "y" ] && printf "%s" "$LAST" | wl-copy && exit

        # Uses bc directly without calling an extra sed fork to strip trailing zeros
        LAST=$(echo "$LAST$NEXT" | bc -l)
        case "$LAST" in *.*) LAST=${LAST%%0}; LAST=${LAST%.};; esac
    done
}

exec_fuzzel_todo() {
    touch "$CACHE_TODO"
    # Replacing the heavy `wc -l` call with basic string manipulation to get lines
    cache_contents=$(cat "$CACHE_TODO")
    cache_lines=$(printf "%s" "$cache_contents" | grep -c "^")

    selection=$(printf "%s" "$cache_contents" | fuzzel --dmenu -l "${cache_lines:-0}")
    [ -z "$selection" ] && exit

    # Clean in-file editing without breaking stream pipes
    if grep -Fxq "$selection" "$CACHE_TODO"; then
        grep -Fxv "$selection" "$CACHE_TODO" > "$CACHE_TODO_TMP" || true
        mv "$CACHE_TODO_TMP" "$CACHE_TODO"
    else
        printf "%s\n" "$selection" >> "$CACHE_TODO"
    fi
}

exec_fuzzel_run() {
    # HUGE optimization: Replaced the massive loop of tr, xargs, find, and sort
    # with fuzzel's native, optimized binary tracking mode.
    selected=$(fuzzel --dmenu < /dev/null)
    [ -n "$selected" ] && exec "$selected"
}

# --- Menu Data Definitions (Using continuous clean formatting escape sequences) ---
main_menu="🖥️ Terminal\n🗃️ Explorer\n📦 Apps\n⚙️ Utils\n🔌 Power"
utils_menu="📑 Todo\n💻 Streaming\n🔢 Calc\n⚙️ Run\n⌨️ Keyboard"
power_menu=" Shutdown\n Suspend\n Reboot\n Lock"
streaming_menu=" Media\n Twitch"
media_type_menu=" Video\n Audio"

# --- Main Logic Pipeline ---
case "$(show_menu "$main_menu" 12 5)" in
    "🖥️ Terminal") launch_app alacritty ;;
    "🗃️ Explorer") launch_app pcmanfm-qt ;;
    "📦 Apps")      launch_app fuzzel ;;
    "⚙️ Utils")    handle_utils_menu ;;
    "🔌 Power")    handle_power_menu ;;
esac
