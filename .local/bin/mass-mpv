#!/bin/bash

# Convert TARGET_DIR to an absolute path immediately
TARGET_DIR="$(realpath "${1:-.}")"

TMP_INPUT_CONF=$(mktemp)
TMP_PLAYLIST=$(mktemp)

trap 'rm -f "$TMP_INPUT_CONF" "$TMP_PLAYLIST"' EXIT

# Custom keybindings
cat > "$TMP_INPUT_CONF" <<EOF
LEFT playlist-prev
RIGHT playlist-next
KP_PLUS add video-zoom 0.1
KP_MINUS add video-zoom -0.1
ENTER playlist-next
BACKSPACE playlist-prev
# Added seek controls for videos
UP add seek 60
DOWN add seek -60
EOF

# Define supported extensions
IMG_EXT="jpg|jpeg|png|gif|webp"
VID_EXT="mp4|mkv|mov|avi|webm|flv|wmv|m4v|m4a"

# find using extended regex to catch both images and videos
find "$TARGET_DIR" -type f -regextype posix-extended \
    -iregex ".*\.($IMG_EXT|$VID_EXT)" -print0 | \
    shuf -z | tr '\0' '\n' > "$TMP_PLAYLIST"

if [ ! -s "$TMP_PLAYLIST" ]; then
  echo "No media files found in $TARGET_DIR" >&2
  exit 1
fi

mpv --input-conf="$TMP_INPUT_CONF" \
    --playlist="$TMP_PLAYLIST" \
    --vo=gpu \
    --image-display-duration=5 \
    --loop-playlist=inf \
    --osd-level=1 \
    --reset-on-next-file=video-zoom
