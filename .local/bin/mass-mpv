#!/bin/bash

# Convert TARGET_DIR to an absolute path immediately
TARGET_DIR="$(realpath "${1:-.}")"

TMP_INPUT_CONF=$(mktemp)
TMP_PLAYLIST=$(mktemp)

trap 'rm -f "$TMP_INPUT_CONF" "$TMP_PLAYLIST"' EXIT

cat > "$TMP_INPUT_CONF" <<EOF
LEFT playlist-prev
RIGHT playlist-next
KP_PLUS add video-zoom 0.1
KP_MINUS add video-zoom -0.1
ENTER playlist-next
BACKSPACE playlist-prev
EOF

# find will now output absolute paths because $TARGET_DIR is absolute
find "$TARGET_DIR" -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.gif' -o -iname '*.webp' \) -print0 | shuf -z | tr '\0' '\n' > "$TMP_PLAYLIST"

if [ ! -s "$TMP_PLAYLIST" ]; then
  echo "No images found in $TARGET_DIR" >&2
  exit 1
fi

mpv --input-conf="$TMP_INPUT_CONF" \
    --playlist="$TMP_PLAYLIST" \
    --vo=gpu \
    --image-display-duration=5 \
    --loop-playlist=inf
