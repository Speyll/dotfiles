#!/bin/bash

# ProtonVPN Configuration File
CONFIG_FILE="$HOME/.var/openvpn/protonvpn.ovpn"

# Function to connect to ProtonVPN
connect() {
    sudo openvpn --config "$CONFIG_FILE"
}

# Function to disconnect from ProtonVPN
disconnect() {
    sudo pkill -f "openvpn --config $CONFIG_FILE"
    sudo killall -SIGINT openvpn
}

# Main script
echo "ProtonVPN Script"
echo "1. Connect to ProtonVPN"
echo "2. Disconnect from ProtonVPN"
read -p "Choose an option (1/2): " choice

case $choice in
    1)
        connect
        ;;
    2)
        disconnect
        ;;
    *)
        echo "Invalid option. Exiting."
        ;;
esac
